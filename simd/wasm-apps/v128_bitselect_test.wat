;; v128_bitselect_test.wat - WebAssembly Text Format for v128.bitselect opcode testing

(module
  ;; Function: test_bitselect
  ;; Description: Performs v128.bitselect operation on three input v128 vectors
  ;; Parameters: Twelve i32 values representing three v128 inputs (4+4+4)
  ;; Returns: Four i32 values representing v128 result
  (func $test_bitselect (export "test_bitselect")
    (param $in1_0 i32) (param $in1_1 i32) (param $in1_2 i32) (param $in1_3 i32)
    (param $in2_0 i32) (param $in2_1 i32) (param $in2_2 i32) (param $in2_3 i32)
    (param $in3_0 i32) (param $in3_1 i32) (param $in3_2 i32) (param $in3_3 i32)
    (result i32 i32 i32 i32)
    (local $vector_a v128)
    (local $vector_b v128)
    (local $vector_mask v128)
    (local $result v128)

    ;; Create first v128 vector (a) from four i32 values
    (v128.const i32x4 0 0 0 0)
    (local.get $in1_0)
    (i32x4.replace_lane 0)
    (local.get $in1_1)
    (i32x4.replace_lane 1)
    (local.get $in1_2)
    (i32x4.replace_lane 2)
    (local.get $in1_3)
    (i32x4.replace_lane 3)
    (local.set $vector_a)

    ;; Create second v128 vector (b) from four i32 values
    (v128.const i32x4 0 0 0 0)
    (local.get $in2_0)
    (i32x4.replace_lane 0)
    (local.get $in2_1)
    (i32x4.replace_lane 1)
    (local.get $in2_2)
    (i32x4.replace_lane 2)
    (local.get $in2_3)
    (i32x4.replace_lane 3)
    (local.set $vector_b)

    ;; Create mask v128 vector from four i32 values
    (v128.const i32x4 0 0 0 0)
    (local.get $in3_0)
    (i32x4.replace_lane 0)
    (local.get $in3_1)
    (i32x4.replace_lane 1)
    (local.get $in3_2)
    (i32x4.replace_lane 2)
    (local.get $in3_3)
    (i32x4.replace_lane 3)
    (local.set $vector_mask)

    ;; Apply v128.bitselect operation: result = (a & mask) | (b & ~mask)
    (local.get $vector_a)
    (local.get $vector_b)
    (local.get $vector_mask)
    (v128.bitselect)
    (local.set $result)

    ;; Extract and return four i32 values
    (local.get $result)
    (i32x4.extract_lane 0)
    (local.get $result)
    (i32x4.extract_lane 1)
    (local.get $result)
    (i32x4.extract_lane 2)
    (local.get $result)
    (i32x4.extract_lane 3)
  )

  ;; Additional test functions for specific scenarios

  ;; Test function with all-zeros mask
  (func $test_bitselect_zeros_mask (export "test_bitselect_zeros_mask")
    (param $in1_0 i32) (param $in1_1 i32) (param $in1_2 i32) (param $in1_3 i32)
    (param $in2_0 i32) (param $in2_1 i32) (param $in2_2 i32) (param $in2_3 i32)
    (result i32 i32 i32 i32)
    (local $vector_a v128)
    (local $vector_b v128)
    (local $result v128)

    ;; Create first v128 vector (a)
    (v128.const i32x4 0 0 0 0)
    (local.get $in1_0)
    (i32x4.replace_lane 0)
    (local.get $in1_1)
    (i32x4.replace_lane 1)
    (local.get $in1_2)
    (i32x4.replace_lane 2)
    (local.get $in1_3)
    (i32x4.replace_lane 3)
    (local.set $vector_a)

    ;; Create second v128 vector (b)
    (v128.const i32x4 0 0 0 0)
    (local.get $in2_0)
    (i32x4.replace_lane 0)
    (local.get $in2_1)
    (i32x4.replace_lane 1)
    (local.get $in2_2)
    (i32x4.replace_lane 2)
    (local.get $in2_3)
    (i32x4.replace_lane 3)
    (local.set $vector_b)

    ;; Apply bitselect with all-zeros mask (should select vector b)
    (local.get $vector_a)
    (local.get $vector_b)
    (v128.const i32x4 0 0 0 0)
    (v128.bitselect)
    (local.set $result)

    ;; Extract and return four i32 values
    (local.get $result)
    (i32x4.extract_lane 0)
    (local.get $result)
    (i32x4.extract_lane 1)
    (local.get $result)
    (i32x4.extract_lane 2)
    (local.get $result)
    (i32x4.extract_lane 3)
  )

  ;; Test function with all-ones mask
  (func $test_bitselect_ones_mask (export "test_bitselect_ones_mask")
    (param $in1_0 i32) (param $in1_1 i32) (param $in1_2 i32) (param $in1_3 i32)
    (param $in2_0 i32) (param $in2_1 i32) (param $in2_2 i32) (param $in2_3 i32)
    (result i32 i32 i32 i32)
    (local $vector_a v128)
    (local $vector_b v128)
    (local $result v128)

    ;; Create first v128 vector (a)
    (v128.const i32x4 0 0 0 0)
    (local.get $in1_0)
    (i32x4.replace_lane 0)
    (local.get $in1_1)
    (i32x4.replace_lane 1)
    (local.get $in1_2)
    (i32x4.replace_lane 2)
    (local.get $in1_3)
    (i32x4.replace_lane 3)
    (local.set $vector_a)

    ;; Create second v128 vector (b)
    (v128.const i32x4 0 0 0 0)
    (local.get $in2_0)
    (i32x4.replace_lane 0)
    (local.get $in2_1)
    (i32x4.replace_lane 1)
    (local.get $in2_2)
    (i32x4.replace_lane 2)
    (local.get $in2_3)
    (i32x4.replace_lane 3)
    (local.set $vector_b)

    ;; Apply bitselect with all-ones mask (should select vector a)
    (local.get $vector_a)
    (local.get $vector_b)
    (v128.const i32x4 0xFFFFFFFF 0xFFFFFFFF 0xFFFFFFFF 0xFFFFFFFF)
    (v128.bitselect)
    (local.set $result)

    ;; Extract and return four i32 values
    (local.get $result)
    (i32x4.extract_lane 0)
    (local.get $result)
    (i32x4.extract_lane 1)
    (local.get $result)
    (i32x4.extract_lane 2)
    (local.get $result)
    (i32x4.extract_lane 3)
  )

  ;; Test function with alternating mask pattern
  (func $test_bitselect_alternating_mask (export "test_bitselect_alternating_mask")
    (param $in1_0 i32) (param $in1_1 i32) (param $in1_2 i32) (param $in1_3 i32)
    (param $in2_0 i32) (param $in2_1 i32) (param $in2_2 i32) (param $in2_3 i32)
    (result i32 i32 i32 i32)
    (local $vector_a v128)
    (local $vector_b v128)
    (local $result v128)

    ;; Create first v128 vector (a)
    (v128.const i32x4 0 0 0 0)
    (local.get $in1_0)
    (i32x4.replace_lane 0)
    (local.get $in1_1)
    (i32x4.replace_lane 1)
    (local.get $in1_2)
    (i32x4.replace_lane 2)
    (local.get $in1_3)
    (i32x4.replace_lane 3)
    (local.set $vector_a)

    ;; Create second v128 vector (b)
    (v128.const i32x4 0 0 0 0)
    (local.get $in2_0)
    (i32x4.replace_lane 0)
    (local.get $in2_1)
    (i32x4.replace_lane 1)
    (local.get $in2_2)
    (i32x4.replace_lane 2)
    (local.get $in2_3)
    (i32x4.replace_lane 3)
    (local.set $vector_b)

    ;; Apply bitselect with alternating mask (0xAAAAAAAA pattern)
    (local.get $vector_a)
    (local.get $vector_b)
    (v128.const i32x4 0xAAAAAAAA 0xAAAAAAAA 0xAAAAAAAA 0xAAAAAAAA)
    (v128.bitselect)
    (local.set $result)

    ;; Extract and return four i32 values
    (local.get $result)
    (i32x4.extract_lane 0)
    (local.get $result)
    (i32x4.extract_lane 1)
    (local.get $result)
    (i32x4.extract_lane 2)
    (local.get $result)
    (i32x4.extract_lane 3)
  )
)